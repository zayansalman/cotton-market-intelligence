# Copy to .env for local/docker-compose (never commit .env).

# Required for full pipeline + dashboard snapshot with live numbers:
# COTTON_DAILY_DATA_LOCAL_FILEPATH=/path/to/cotton-prices-historical-chart-data.csv

# Optional:
# WB_COMMODITIES_DATA_LOCAL_FILEPATH=/path/to/CMO-Historical-Data-Monthly.xlsx

# Dashboard reads this JSON (CI writes it to artifacts/):
# CMI_PIPELINE_SNAPSHOT=/app/artifacts/pipeline_snapshot.json

# Hugging Face NLP (optional; pip install -r requirements-ml.txt)
# CMI_USE_HF_NLP=1
# CMI_HF_SENTIMENT_MODEL=ProsusAI/finbert
# HF_HOME=/var/cache/huggingface

# OpenAI narrative (optional)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
