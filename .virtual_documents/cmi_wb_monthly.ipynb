def find_cols(df, word):
    """
    Find columns in a DataFrame that contain a specific word.

    Parameters:
        df (DataFrame): The DataFrame to search.
        word (str): The word to search for in column names.

    Returns:
        list: A list of column names containing the specified word.
    """
    return [col for col in df.columns if word in col]


# Define a function to remove outliers from a column
def remove_outliers(df):
    z_scores = np.abs(stats.zscore(df))
    threshold = 3
    return df[(z_scores < threshold)]


# Define a function to get outliers from a column
def get_outliers(df):
    z_scores = np.abs(stats.zscore(df))
    threshold = 3
    return df[(z_scores > threshold)]


def get_fred_data(start_date, end_date, fred_codes_dict={'CPI':'CPIAUCSL'}):
    # make fred codes a ditch with name as key and value as code 
    codes_df_list = []
    codes_df = pd.DataFrame()
    for name, code in fred_codes_dict.items():
        data = pdr.get_data_fred(code, start=start_date, end=end_date)
        data[name] = data[code]
        codes_df_list.append(data)
    codes_df = pd.concat(codes_df_list, axis=1, ignore_index=False).drop(columns=list(fred_codes_dict.values()))
    return codes_df





